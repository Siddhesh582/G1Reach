<!--
  g1_upper.xml — Unitree G1 upper-body MuJoCo MJCF model
  Fixed base (no freejoint) — pelvis welded to world for upper-body reaching task.
-->
<mujoco model="g1_upper_body">
  <compiler angle="radian" meshdir="." autolimits="true"/>

  <option timestep="0.005" gravity="0 0 -9.81" iterations="100" solver="Newton"
          tolerance="1e-10"/>

  <default>
    <joint damping="5.0" armature="0.05" frictionloss="0.01"/>
    <geom contype="1" conaffinity="1" condim="3" friction="0.8 0.02 0.001" rgba="0.5 0.5 0.8 1"/>
    <position kp="100" kv="10"/>
    <site size="0.02" rgba="1 0 0 1"/>
  </default>

  <worldbody>
    <!-- Ground plane -->
    <geom name="floor" type="plane" size="5 5 0.1" rgba="0.7 0.7 0.7 1"
          contype="1" conaffinity="1"/>

    <!-- Pelvis: FIXED to world (no freejoint) -->
    <body name="pelvis" pos="0 0 0.9">
      <geom name="pelvis_geom" type="box" size="0.12 0.08 0.1" mass="10.0"
            rgba="0.3 0.3 0.8 1" contype="0" conaffinity="0"/>

      <!-- Torso -->
      <body name="torso_link" pos="0 0 0.15">
        <joint name="torso_joint" type="hinge" axis="0 0 1"
               range="-0.5 0.5" damping="10.0" armature="0.1"/>
        <geom name="torso_geom" type="box" size="0.12 0.08 0.2" mass="8.0"
              rgba="0.3 0.5 0.8 1" contype="0" conaffinity="0"/>

        <!-- ── LEFT ARM ──────────────────────────────────────────── -->
        <body name="left_shoulder_link" pos="-0.18 0 0.15">
          <joint name="left_shoulder_pitch_joint" type="hinge" axis="0 1 0"
                 range="-3.14 2.09" damping="5.0" armature="0.05"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.12" size="0.04" mass="1.5"
                contype="0" conaffinity="0"/>

          <body name="left_shoulder_roll_link" pos="0 0 -0.12">
            <joint name="left_shoulder_roll_joint" type="hinge" axis="1 0 0"
                   range="-1.57 2.87" damping="5.0" armature="0.05"/>
            <geom type="capsule" fromto="0 0 0 0 0 -0.06" size="0.035" mass="0.8"
                  contype="0" conaffinity="0"/>

            <body name="left_shoulder_yaw_link" pos="0 0 -0.06">
              <joint name="left_shoulder_yaw_joint" type="hinge" axis="0 0 1"
                     range="-1.57 1.57" damping="3.0" armature="0.02"/>
              <geom type="capsule" fromto="0 0 0 0 0 -0.22" size="0.03" mass="1.2"
                    contype="0" conaffinity="0"/>

              <body name="left_elbow_link" pos="0 0 -0.22">
                <joint name="left_elbow_joint" type="hinge" axis="0 1 0"
                       range="-1.57 2.09" damping="3.0" armature="0.02"/>
                <geom type="capsule" fromto="0 0 0 0 0 -0.2" size="0.028" mass="0.9"
                      contype="0" conaffinity="0"/>

                <body name="left_wrist_roll_link" pos="0 0 -0.2">
                  <joint name="left_wrist_roll_joint" type="hinge" axis="1 0 0"
                         range="-1.57 1.57" damping="1.0" armature="0.01"/>
                  <geom type="capsule" fromto="0 0 0 0 0 -0.05" size="0.02" mass="0.2"
                        contype="0" conaffinity="0"/>

                  <body name="left_wrist_pitch_link" pos="0 0 -0.05">
                    <joint name="left_wrist_pitch_joint" type="hinge" axis="0 1 0"
                           range="-1.57 1.57" damping="1.0" armature="0.01"/>
                    <geom type="capsule" fromto="0 0 0 0 0 -0.05" size="0.02" mass="0.2"
                          contype="0" conaffinity="0"/>

                    <body name="left_wrist_yaw_link" pos="0 0 -0.05">
                      <joint name="left_wrist_yaw_joint" type="hinge" axis="0 0 1"
                             range="-1.57 1.57" damping="1.0" armature="0.01"/>
                      <geom type="sphere" size="0.035" mass="0.3"
                            rgba="0.2 0.8 0.2 1" contype="0" conaffinity="0"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>

        <!-- ── RIGHT ARM ─────────────────────────────────────────── -->
        <body name="right_shoulder_link" pos="0.18 0 0.15">
          <joint name="right_shoulder_pitch_joint" type="hinge" axis="0 1 0"
                 range="-3.14 2.09" damping="5.0" armature="0.05"/>
          <geom type="capsule" fromto="0 0 0 0 0 -0.12" size="0.04" mass="1.5"
                contype="0" conaffinity="0"/>

          <body name="right_shoulder_roll_link" pos="0 0 -0.12">
            <joint name="right_shoulder_roll_joint" type="hinge" axis="1 0 0"
                   range="-2.87 1.57" damping="5.0" armature="0.05"/>
            <geom type="capsule" fromto="0 0 0 0 0 -0.06" size="0.035" mass="0.8"
                  contype="0" conaffinity="0"/>

            <body name="right_shoulder_yaw_link" pos="0 0 -0.06">
              <joint name="right_shoulder_yaw_joint" type="hinge" axis="0 0 1"
                     range="-1.57 1.57" damping="3.0" armature="0.02"/>
              <geom type="capsule" fromto="0 0 0 0 0 -0.22" size="0.03" mass="1.2"
                    contype="0" conaffinity="0"/>

              <body name="right_elbow_link" pos="0 0 -0.22">
                <joint name="right_elbow_joint" type="hinge" axis="0 1 0"
                       range="-1.57 2.09" damping="3.0" armature="0.02"/>
                <geom type="capsule" fromto="0 0 0 0 0 -0.2" size="0.028" mass="0.9"
                      contype="0" conaffinity="0"/>

                <body name="right_wrist_roll_link" pos="0 0 -0.2">
                  <joint name="right_wrist_roll_joint" type="hinge" axis="1 0 0"
                         range="-1.57 1.57" damping="1.0" armature="0.01"/>
                  <geom type="sphere" size="0.035" mass="0.5"
                        rgba="0.8 0.2 0.2 1" contype="0" conaffinity="0"/>

                  <!-- RIGHT HAND END-EFFECTOR SITE -->
                  <site name="right_hand_site" pos="0 0 -0.06" size="0.025" rgba="1 1 0 1"/>
                </body>
              </body>
            </body>
          </body>
        </body>

      </body><!-- torso -->
    </body><!-- pelvis — fixed, no joint -->

    <!-- Target visualisation sphere (moved by env at each reset) -->
    <body name="target_body" pos="0.2 0 -0.25" mocap="true">
      <geom name="target_geom" type="sphere" size="0.05"
            rgba="0 1 0 0.5" contype="0" conaffinity="0"/>
    </body>

  </worldbody>

  <!-- ── Actuators (position control) ──────────────────────────────────── -->
  <actuator>
    <position name="torso_act"                  joint="torso_joint"                 kp="200" kv="20"/>
    <position name="left_shoulder_pitch_act"    joint="left_shoulder_pitch_joint"   kp="150" kv="15"/>
    <position name="left_shoulder_roll_act"     joint="left_shoulder_roll_joint"    kp="150" kv="15"/>
    <position name="left_shoulder_yaw_act"      joint="left_shoulder_yaw_joint"     kp="80"  kv="8"/>
    <position name="left_elbow_act"             joint="left_elbow_joint"            kp="100" kv="10"/>
    <position name="left_wrist_roll_act"        joint="left_wrist_roll_joint"       kp="30"  kv="3"/>
    <position name="left_wrist_pitch_act"       joint="left_wrist_pitch_joint"      kp="30"  kv="3"/>
    <position name="left_wrist_yaw_act"         joint="left_wrist_yaw_joint"        kp="30"  kv="3"/>
    <position name="right_shoulder_pitch_act"   joint="right_shoulder_pitch_joint"  kp="150" kv="15"/>
    <position name="right_shoulder_roll_act"    joint="right_shoulder_roll_joint"   kp="150" kv="15"/>
    <position name="right_shoulder_yaw_act"     joint="right_shoulder_yaw_joint"    kp="80"  kv="8"/>
    <position name="right_elbow_act"            joint="right_elbow_joint"           kp="100" kv="10"/>
    <position name="right_wrist_roll_act"       joint="right_wrist_roll_joint"      kp="30"  kv="3"/>
  </actuator>

  <sensor>
    <framepos name="ee_pos_sensor" objtype="site" objname="right_hand_site"/>
  </sensor>

</mujoco>